# -----------------------------------------------------------------------------
# Magic Card Finder – environment variables example
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in real values. Do not commit .env to git.
#   cp .env.dist .env
# -----------------------------------------------------------------------------

# ----- Logging -----
# Level for pricing/API client logs (INFO shows flow, HTTP calls, response codes; DEBUG for more)
# LOG_LEVEL=INFO

# ----- Detector service (YOLO) -----
# URL of the YOLO detector microservice. Set by docker-compose for inter-container networking.
DETECTOR_SERVICE_URL=http://detector:8002
# HTTP timeout in seconds for detector requests (default: 120).
# DETECTOR_SERVICE_TIMEOUT=120
# YOLO confidence threshold for detection (default: 0.4)
# YOLO_CONFIDENCE=0.4
# Path to trained model weights inside the container (default: /app/models/mtg_detector/weights/best.pt)
# MODEL_PATH=/app/models/mtg_detector/weights/best.pt
# Optional: write debug images (original, annotated, name crops) to this directory
# DETECTOR_DEBUG_DIR=/tmp/detector-debug
# Roboflow API key for training (obtain at https://app.roboflow.com/settings/api)
ROBOFLOW_API_KEY=

# ----- OCR service (Tesseract) -----
# URL of the Tesseract OCR microservice. Set by docker-compose for inter-container networking.
OCR_SERVICE_URL=http://ocr:8003
# HTTP timeout in seconds for OCR requests (default: 120).
# OCR_SERVICE_TIMEOUT=120
# Tesseract language packs to use (default: eng+ita+fra+spa+deu)
# TESSERACT_LANGS=eng+ita+fra+spa+deu
# Optional: write OCR debug images (ROI + preprocessed) to this directory
# OCR_DEBUG_DIR=/tmp/ocr-debug

# ----- Database -----
# Override only if not using docker-compose defaults. Compose sets this for the backend.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/magic_cards

# ----- Optional: Open TCG API (tcgtracking.com) -----
# Set to 1 to enable when the client is implemented. No API key required.
OPEN_TCG_API_ENABLED=0
# Optional base URL override
# OPEN_TCG_API_BASE_URL=https://tcgtracking.com/tcgapi/v1

# ----- Optional: Cardmarket API -----
# Set to 1 to enable when the client is implemented. You must also set the OAuth vars below.
CARDMARKET_API_ENABLED=0
# OAuth 1.0 credentials from your Cardmarket developer app.
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_TOKEN_SECRET=

# ----- Optional: CardTrader API -----
# Set to 1 to enable. Get your token from CardTrader profile settings.
CARDTRADER_API_ENABLED=0
CARDTRADER_API_TOKEN=
# Optional base URL override (default: https://api.cardtrader.com/api/v2)
# CARDTRADER_API_BASE_URL=https://api.cardtrader.com/api/v2

# Optional: language filter for CardTrader (mtg_language, e.g. en, it, fr)
# CARDTRADER_LANGUAGE=en

# ----- Frontend (Docker only) -----
# Set by docker-compose so the dev server proxies /api to the backend container.
# Only needed if you override the default; local dev uses http://localhost:8000.
# VITE_PROXY_TARGET=http://backend:8000

LOG_LEVEL=DEBUG
